@model IEnumerable<QDPhone.Web.Models.Entities.Brand>
@{
    ViewData["Title"] = "Thương hiệu";
}
<div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h4 class="mb-1 fw-semibold">Quản lý thương hiệu</h4>
        <div class="page-breadcrumb">Danh sách thương hiệu đang hoạt động</div>
    </div>
    <a class="btn btn-danger" asp-action="Create"><i class="bi bi-plus-circle"></i> Thêm thương hiệu</a>
</div>
<div class="admin-card">
    <div class="row g-3">
        @foreach (var b in Model)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="border rounded p-3 h-100">
                    <img src="@(string.IsNullOrWhiteSpace(b.ImageUrl) ? "https://via.placeholder.com/96x48?text=Brand" : b.ImageUrl)" alt="@b.Name" style="width:96px;height:48px;object-fit:contain;" class="mb-2" />
                    <div class="fw-semibold">@b.Name</div>
                    <div class="small text-muted"><code>@b.Slug</code></div>
                    <div class="mt-2 d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <form asp-action="Delete" method="post" class="js-ajax-form" data-success-message="Đã xóa thương hiệu." data-confirm="Xóa thương hiệu này?" data-reload="page">
                            <input type="hidden" name="id" value="@b.Id" />
                            <button class="btn btn-sm btn-outline-danger">Xóa</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

