@model QDPhone.Web.Models.Entities.Brand
@{
    ViewData["Title"] = "Sửa thương hiệu";
}
<div class="page-header mb-4">
    <h4 class="mb-1 fw-semibold">Sửa thương hiệu</h4>
    <div class="page-breadcrumb">Cập nhật tên và slug thương hiệu</div>
</div>
<form method="post" enctype="multipart/form-data" class="admin-card" style="max-width:600px;">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3"><label class="form-label">Tên thương hiệu</label><input asp-for="Name" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Slug</label><input asp-for="Slug" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Logo URL</label><input asp-for="ImageUrl" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Upload logo mới</label><input type="file" name="imageFile" class="form-control" accept="image/*" /></div>
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        <button class="btn btn-danger">Lưu thay đổi</button>
    </div>
</form>

