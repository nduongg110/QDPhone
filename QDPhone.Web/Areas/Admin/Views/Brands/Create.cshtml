@model QDPhone.Web.Models.Entities.Brand
@{
    ViewData["Title"] = "Tạo thương hiệu";
}
<div class="page-header mb-4">
    <h4 class="mb-1 fw-semibold">Tạo thương hiệu mới</h4>
    <div class="page-breadcrumb">Thêm tên và slug cho thương hiệu</div>
</div>
<form method="post" enctype="multipart/form-data" class="admin-card" style="max-width:600px;">
    <div class="mb-3"><label class="form-label">Tên thương hiệu</label><input asp-for="Name" class="form-control" /></div>
    <div class="mb-3"><label class="form-label">Slug</label><input asp-for="Slug" class="form-control" id="brandSlug" /></div>
    <div class="mb-3"><label class="form-label">Logo URL</label><input asp-for="ImageUrl" class="form-control" placeholder="/uploads/brands/... hoặc https://..." /></div>
    <div class="mb-3"><label class="form-label">Upload logo</label><input type="file" name="imageFile" class="form-control" accept="image/*" /></div>
    <div class="d-flex justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        <button class="btn btn-danger">Lưu</button>
    </div>
</form>
@section Scripts {
    <script>
        const nameInput = document.querySelector('[name="Name"]');
        const slugInput = document.getElementById('brandSlug');
        if (nameInput && slugInput) nameInput.addEventListener('blur', () => { if (!slugInput.value) slugInput.value = slugifyVi(nameInput.value); });
    </script>
}

