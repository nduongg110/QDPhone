@model QDPhone.Web.Models.ViewModels.AdminBannerIndexViewModel
@{
    ViewData["Title"] = "Quản lý banner";
}
<div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h4 class="mb-1 fw-semibold">Quản lý banner</h4>
        <div class="page-breadcrumb">Theo dõi banner hiển thị trên trang chủ</div>
    </div>
    <a class="btn btn-danger" asp-action="Create"><i class="bi bi-plus-circle"></i> Thêm banner</a>
</div>
<div class="admin-card">
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-6"><input class="form-control" name="q" value="@Model.Q" placeholder="Tìm tiêu đề hoặc link..." /></div>
        <div class="col-md-3">
            <select class="form-select" name="isActive">
                <option value="" selected="@(!Model.IsActive.HasValue ? "selected" : null)">Tất cả trạng thái</option>
                <option value="true" selected="@(Model.IsActive == true ? "selected" : null)">Đang bật</option>
                <option value="false" selected="@(Model.IsActive == false ? "selected" : null)">Đang tắt</option>
            </select>
        </div>
        <div class="col-md-3 d-grid d-md-flex gap-2">
            <button class="btn btn-outline-primary">Lọc</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
        </div>
    </form>
    <div class="table-responsive">
        <table class="table table-hover admin-table mb-0">
            <thead><tr><th>Banner</th><th>Link</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
            <tbody>
            @foreach (var b in Model.Rows)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <img src="@b.ImageUrl" alt="@b.Title" style="width:120px;height:42px;object-fit:cover;border-radius:6px;" />
                            <div class="fw-semibold">@b.Title</div>
                        </div>
                    </td>
                    <td><a href="@b.LinkUrl" target="_blank">@b.LinkUrl</a></td>
                    <td><span class="badge @(b.IsActive ? "text-bg-success" : "text-bg-secondary")">@(b.IsActive ? "Active" : "Tắt")</span></td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-secondary">Sửa</a>
                        <form asp-action="Delete" method="post" class="d-inline js-ajax-form" data-success-message="Đã xóa banner." data-confirm="Xóa banner này?" data-reload="row">
                            <input type="hidden" name="id" value="@b.Id" />
                            <button class="btn btn-sm btn-outline-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                <a class="page-link" asp-action="Index" asp-route-q="@Model.Q" asp-route-isActive="@Model.IsActive" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Trước</a>
            </li>
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : null)">
                    <a class="page-link" asp-action="Index" asp-route-q="@Model.Q" asp-route-isActive="@Model.IsActive" asp-route-page="@p" asp-route-pageSize="@Model.PageSize">@p</a>
                </li>
            }
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                <a class="page-link" asp-action="Index" asp-route-q="@Model.Q" asp-route-isActive="@Model.IsActive" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Sau</a>
            </li>
        </ul>
    </nav>
}

