@model QDPhone.Web.Models.ViewModels.ProductCreateViewModel
@{
    ViewData["Title"] = "Sửa sản phẩm";
}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 fw-semibold">Sửa sản phẩm</h4>
        <div class="page-breadcrumb">Cập nhật thông tin sản phẩm và biến thể mặc định</div>
    </div>
</div>
<form method="post" enctype="multipart/form-data" class="admin-card">
    <div class="row g-3">
        <div class="col-md-8"><label class="form-label">Tên sản phẩm</label><input asp-for="Name" class="form-control" /></div>
        <div class="col-md-4"><label class="form-label">Slug</label><input asp-for="Slug" class="form-control" id="productSlug" /></div>
        <div class="col-md-6">
            <label class="form-label">Hãng</label>
            <select asp-for="BrandId" class="form-select">
                @foreach (var b in Model.Brands) { <option value="@b.Id">@b.Name</option> }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Danh mục</label>
            <select asp-for="CategoryId" class="form-select">
                @foreach (var c in Model.Categories) { <option value="@c.Id">@c.Name</option> }
            </select>
        </div>
        <div class="col-md-12"><label class="form-label">Mô tả</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
        <div class="col-md-3"><label class="form-label">Hệ điều hành</label><input asp-for="OperatingSystem" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">RAM</label><input asp-for="Ram" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">ROM</label><input asp-for="Rom" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">Màu sắc</label><input asp-for="Color" class="form-control" /></div>
        <div class="col-md-6"><label class="form-label">Giá bán</label><input asp-for="Price" class="form-control" /></div>
        <div class="col-md-6"><label class="form-label">Tồn kho</label><input asp-for="StockQuantity" class="form-control" /></div>
        <div class="col-md-6"><label class="form-label">Ảnh đại diện URL</label><input asp-for="PrimaryImageUrl" class="form-control" /></div>
        <div class="col-md-6"><label class="form-label">Upload ảnh đại diện mới</label><input type="file" name="primaryImageFile" class="form-control" accept="image/*" /></div>
    </div>
    <div class="mt-3 d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        <button class="btn btn-danger">Lưu thay đổi</button>
    </div>
</form>

