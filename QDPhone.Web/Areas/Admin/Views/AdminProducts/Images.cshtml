@model QDPhone.Web.Models.Entities.Product
@{
    ViewData["Title"] = "Quản lý ảnh sản phẩm";
    var orderedImages = Model.Images.OrderBy(x => x.SortOrder).ToList();
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h4 class="mb-1 fw-semibold">Quản lý ảnh: @Model.Name</h4>
        <div class="page-breadcrumb">Thêm ảnh, đặt ảnh chính và sắp xếp hiển thị</div>
    </div>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">← Quay lại danh sách</a>
</div>

<form asp-action="AddImage" method="post" enctype="multipart/form-data" class="admin-card row g-2 mb-4">
    <input type="hidden" name="productId" value="@Model.Id" />
    <div class="col-md-5">
        <label class="form-label">URL ảnh</label>
        <input class="form-control form-control-sm" type="url" name="imageUrl" placeholder="https://... (không bắt buộc)" />
    </div>
    <div class="col-md-5">
        <label class="form-label">Upload từ máy</label>
        <input class="form-control form-control-sm" type="file" name="imageFile" accept="image/*" />
    </div>
    <div class="col-md-2 d-flex align-items-end">
        <button class="btn btn-sm btn-danger w-100" type="submit">Thêm ảnh</button>
    </div>
</form>

@if (!orderedImages.Any())
{
    <div class="admin-card"><div class="alert alert-warning mb-0">Chưa có ảnh nào cho sản phẩm này.</div></div>
}
else
{
    <div class="row g-3">
        @foreach (var image in orderedImages)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="admin-card h-100 p-2">
                    <img src="@image.ImageUrl" class="card-img-top" style="height:220px;object-fit:cover;" alt="@Model.Name" />
                    <div class="card-body d-grid gap-2">
                        <div class="small text-muted text-break">@image.ImageUrl</div>

                        <form asp-action="UpdateSortOrder" method="post" class="d-flex gap-2">
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="hidden" name="imageId" value="@image.Id" />
                            <input type="number" min="0" class="form-control form-control-sm" name="sortOrder" value="@image.SortOrder" />
                            <button class="btn btn-sm btn-outline-primary" type="submit">Lưu STT</button>
                        </form>

                        <form asp-action="SetPrimaryImage" method="post">
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="hidden" name="imageId" value="@image.Id" />
                            <button class="btn btn-sm @(image.IsPrimary ? "btn-success" : "btn-outline-success") w-100" type="submit">
                                @(image.IsPrimary ? "Ảnh chính" : "Đặt làm ảnh chính")
                            </button>
                        </form>

                        <form asp-action="DeleteImage" method="post" onsubmit="return confirm('Xóa ảnh này?');">
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="hidden" name="imageId" value="@image.Id" />
                            <button class="btn btn-sm btn-outline-danger w-100" type="submit">Xóa ảnh</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

