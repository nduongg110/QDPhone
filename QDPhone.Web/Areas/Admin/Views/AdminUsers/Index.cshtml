@model QDPhone.Web.Models.ViewModels.AdminUserIndexViewModel
@{
    ViewData["Title"] = "Quản lý người dùng";
    var totalActive = Model.Rows.Count(x => x.User.IsActive);
    var totalLocked = Model.Rows.Count - totalActive;
}
<div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h4 class="mb-1 fw-semibold">Quản lý người dùng</h4>
        <div class="page-breadcrumb">Theo dõi tài khoản và phân quyền truy cập</div>
    </div>
    <a asp-action="Create" class="btn btn-danger">Tạo người dùng</a>
</div>

<div class="row g-2 mb-3">
    <div class="col-md-4"><div class="admin-card py-3"><div class="small text-muted">Tổng người dùng</div><div class="h5 mb-0">@Model.TotalItems</div></div></div>
    <div class="col-md-4"><div class="admin-card py-3"><div class="small text-muted">Đang hoạt động</div><div class="h5 mb-0 text-success">@totalActive</div></div></div>
    <div class="col-md-4"><div class="admin-card py-3"><div class="small text-muted">Đã khóa</div><div class="h5 mb-0 text-danger">@totalLocked</div></div></div>
</div>

<form method="get" class="admin-card row g-2 mb-3">
    <div class="col-md-5">
        <input class="form-control" name="keyword" value="@Model.Keyword" placeholder="Tìm theo email/họ tên..." />
    </div>
    <div class="col-md-3">
        <select class="form-select" name="role">
            <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Role) ? "selected" : null)">Tất cả vai trò</option>
            <option value="User" selected="@(Model.Role == "User" ? "selected" : null)">User</option>
            <option value="Staff" selected="@(Model.Role == "Staff" ? "selected" : null)">Staff</option>
            <option value="Admin" selected="@(Model.Role == "Admin" ? "selected" : null)">Admin</option>
        </select>
    </div>
    <div class="col-md-4 d-grid d-md-flex gap-2">
        <button class="btn btn-outline-primary">Lọc</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Xóa lọc</a>
    </div>
</form>
<div class="admin-card">
    <div class="table-responsive">
        <table class="table table-hover admin-table align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Người dùng</th>
                    <th>Email</th>
                    <th>SĐT</th>
                    <th>Vai trò</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Rows.Select((item, index) => new { item, index }))
            {
                <tr>
                    <td>@((Model.Page - 1) * Model.PageSize + row.index + 1)</td>
                    <td>
                        <div class="fw-semibold">@row.item.User.FullName</div>
                        <div class="text-muted small">@row.item.User.UserName</div>
                    </td>
                    <td><a href="mailto:@row.item.User.Email">@row.item.User.Email</a></td>
                    <td>@(string.IsNullOrWhiteSpace(row.item.User.PhoneNumber) ? "-" : row.item.User.PhoneNumber)</td>
                    <td>
                        <div class="small text-muted mb-1">Hiện tại: <span class="js-user-role-display">@row.item.Role</span></div>
                        <form asp-action="ChangeRole" method="post" class="d-flex gap-2 js-ajax-form" data-success-message="Đã cập nhật vai trò." data-reload="none" data-update="user-role">
                            <input type="hidden" name="userId" value="@row.item.User.Id" />
                            <select name="role" class="form-select form-select-sm">
                                <option value="User" selected="@(row.item.Role == "User" ? "selected" : null)">User</option>
                                <option value="Staff" selected="@(row.item.Role == "Staff" ? "selected" : null)">Staff</option>
                                <option value="Admin" selected="@(row.item.Role == "Admin" ? "selected" : null)">Admin</option>
                            </select>
                            <button class="btn btn-sm btn-outline-primary">Lưu</button>
                        </form>
                    </td>
                    <td>
                        <span class="badge js-user-active-badge @(row.item.User.IsActive ? "text-bg-success" : "text-bg-secondary")">
                            @(row.item.User.IsActive ? "Đang hoạt động" : "Đã khóa")
                        </span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@row.item.User.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <form asp-action="ToggleActive" method="post" class="d-inline js-ajax-form" data-success-message="Đã cập nhật trạng thái tài khoản." data-reload="none" data-update="user-active-toggle">
                            <input type="hidden" name="userId" value="@row.item.User.Id" />
                            <button class="btn btn-sm @(row.item.User.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                @(row.item.User.IsActive ? "Khóa" : "Mở khóa")
                            </button>
                        </form>
                        <form asp-action="Delete" method="post" class="d-inline js-ajax-form" data-confirm="Xóa người dùng này?">
                            <input type="hidden" name="userId" value="@row.item.User.Id" />
                            <button class="btn btn-sm btn-outline-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm flex-wrap">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                <a class="page-link" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-role="@Model.Role" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Trước</a>
            </li>
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : null)">
                    <a class="page-link" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-role="@Model.Role" asp-route-page="@p" asp-route-pageSize="@Model.PageSize">@p</a>
                </li>
            }
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                <a class="page-link" asp-action="Index" asp-route-keyword="@Model.Keyword" asp-route-role="@Model.Role" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Sau</a>
            </li>
        </ul>
    </nav>
}

