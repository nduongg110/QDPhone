@model QDPhone.Web.Models.ViewModels.HomePageViewModel
@{
    ViewData["Title"] = "Trang chủ";
    var activeBanners = Model.Banners.Where(x => !string.IsNullOrWhiteSpace(x.ImageUrl)).ToList();
    var heroBanners = activeBanners.Take(3).ToList();
    var sideBanners = activeBanners.Skip(3).Take(2).ToList();
    var forYouBanners = activeBanners.Skip(5).Take(3).ToList();
    if (!heroBanners.Any())
    {
        heroBanners = new List<QDPhone.Web.Models.Entities.Banner>
        {
            new() { Title = "Ưu đãi điện thoại", ImageUrl = "/uploads/defaults/banner1.png", LinkUrl = "#" },
            new() { Title = "Flagship mới", ImageUrl = "/uploads/defaults/banner2.png", LinkUrl = "#" },
            new() { Title = "Laptop và phụ kiện", ImageUrl = "/uploads/defaults/banner3.png", LinkUrl = "#" }
        };
    }
    if (!sideBanners.Any())
        sideBanners = heroBanners.Take(2).ToList();
    if (!forYouBanners.Any())
        forYouBanners = heroBanners.Take(3).ToList();
    var quickCategories = Model.Categories.ToList();
    var flashSaleItems = Model.FlashSaleProducts.Take(5).ToList();
    var forYouItems = Model.FeaturedProducts.Skip(5).Take(8).ToList();
    var categorySidebar = Model.Categories.Select(x => x.Name).Take(10).ToList();
}

<section class="home-hero mb-4">
    <div class="row g-3">
        <aside class="col-lg-3 d-none d-lg-block">
            <div class="home-catalog card h-100">
                <div class="card-body p-2">
                    @foreach (var item in Model.Categories.Take(10))
                    {
                        <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@item.Id" class="catalog-item">
                            <span>@item.Name</span>
                            <span class="material-symbols-outlined">chevron_right</span>
                        </a>
                    }
                </div>
            </div>
        </aside>
        <div class="col-lg-9">
            <div id="heroCarousel" class="carousel slide h-100" data-bs-ride="carousel" data-bs-interval="4000">
                <div class="carousel-indicators">
                    @for (var i = 0; i < heroBanners.Count; i++)
                    {
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : null)"></button>
                    }
                </div>
                <div class="carousel-inner rounded-3 overflow-hidden">
                    @foreach (var item in heroBanners.Select((value, index) => new { value, index }))
                    {
                        <div class="carousel-item @(item.index == 0 ? "active" : null)">
                            <a href="@item.value.LinkUrl">
                                <img src="@item.value.ImageUrl" class="d-block w-100 hero-img" alt="@item.value.Title" />
                            </a>
                        </div>
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
        </div>
    </div>
</section>

<section class="mb-4">
    <div id="quickCategoryCarousel" class="carousel slide quick-categories-carousel" data-bs-ride="carousel" data-bs-interval="3200">
        <div class="carousel-inner"></div>
        <button class="carousel-control-prev" type="button" data-bs-target="#quickCategoryCarousel" data-bs-slide="prev" aria-label="Danh mục trước">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#quickCategoryCarousel" data-bs-slide="next" aria-label="Danh mục sau">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
    <div id="quickCategoryTemplate" class="d-none">
                @foreach (var c in quickCategories)
        {
            <a asp-controller="Products" asp-action="Index" asp-route-categoryId="@c.Id" class="quick-category text-decoration-none">
                <span class="quick-icon d-inline-flex align-items-center justify-content-center">
                            @if (!string.IsNullOrWhiteSpace(c.ImageUrl))
                            {
                                <img src="@c.ImageUrl" alt="@c.Name" style="width:24px;height:24px;object-fit:cover;border-radius:50%;" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined">apps</span>
                            }
                </span>
                        <span class="quick-label">@c.Name</span>
            </a>
        }
    </div>
</section>

<section class="mb-4">
    <div class="flash-sale-header d-flex align-items-center justify-content-between px-3 py-2 rounded-top">
        <h3 class="mb-0 text-white">Flash Sale Online</h3>
        <div class="flash-sale-countdown" data-target-time="@DateTime.UtcNow.AddHours(8).ToString("o")">08:00:00</div>
    </div>
    <div class="card border-top-0 rounded-top-0">
        <div class="card-body">
            <div class="row g-3 row-cols-2 row-cols-md-4 row-cols-xl-5">
                @foreach (var p in flashSaleItems)
                {
                    <div class="col">
                        <partial name="_ProductCard" model="p" />
                    </div>
                }
            </div>
        </div>
    </div>
</section>


@if (Model.Banners.Any())
{
    <section class="mt-4">
        <div class="row g-3">
            @foreach (var banner in Model.Banners.Take(4))
            {
                <div class="col-6 col-lg-3">
                    <a href="@banner.LinkUrl" class="d-block banner-sub position-relative rounded-3 overflow-hidden text-white">
                        <img src="@banner.ImageUrl" class="w-100" alt="@banner.Title" />
                        <span class="banner-overlay">@banner.Title</span>
                    </a>
                </div>
            }
        </div>
    </section>
}

@if (Model.FeaturedProducts.Any())
{
    <section class="mt-4">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <h2 class="section-title mb-0">Sản phẩm nổi bật</h2>
            <a asp-controller="Products" asp-action="Index" class="btn btn-outline-danger btn-sm">Xem tất cả</a>
        </div>
        <div class="row g-3 row-cols-2 row-cols-md-4 row-cols-xl-5">
            @foreach (var p in Model.FeaturedProducts)
            {
                <div class="col">
                    <partial name="_ProductCard" model="p" />
                </div>
            }
        </div>
    </section>
}

<section class="usp-bar row g-3 mt-4 mb-2 py-3">
    <div class="col-6 col-md-3"><span class="material-symbols-outlined">local_shipping</span>Miễn phí giao hàng toàn quốc</div>
    <div class="col-6 col-md-3"><span class="material-symbols-outlined">cached</span>Đổi trả trong 30 ngày</div>
    <div class="col-6 col-md-3"><span class="material-symbols-outlined">verified_user</span>Cam kết chính hãng 100%</div>
    <div class="col-6 col-md-3"><span class="material-symbols-outlined">support_agent</span>Hỗ trợ 24/7</div>
</section>
