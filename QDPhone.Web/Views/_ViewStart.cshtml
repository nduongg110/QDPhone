@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var area = ViewContext.RouteData.Values["area"]?.ToString();
    var isAuthPage = controller == "Account" && (
        action == "Login" ||
        action == "Register" ||
        action == "ForgotPassword" ||
        action == "ForgotPasswordConfirmation" ||
        action == "ResetPassword" ||
        action == "ResetPasswordConfirmation" ||
        action == "RegisterSuccess" ||
        action == "ConfirmEmailResult" ||
        action == "AccessDenied");
    var isAdminPage = string.Equals(area, "Admin", StringComparison.OrdinalIgnoreCase);

    Layout = isAuthPage ? "_AuthLayout" : isAdminPage ? "_AdminLayout" : "_Layout";
}
