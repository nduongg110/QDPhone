@{
    ViewData["Title"] = "Dashboard";
    var recentOrders = new[]
    {
        (1001, "Nguyễn Văn A", 27_990_000m, "Đã giao", "27/04 09:24"),
        (1002, "Trần Thị B", 18_490_000m, "Đang giao", "27/04 10:11"),
        (1003, "Lê Văn C", 9_990_000m, "Chờ xử lý", "27/04 10:42"),
        (1004, "Phạm Thị D", 32_500_000m, "Hoàn tất", "27/04 11:05"),
        (1005, "Hoàng Văn E", 5_490_000m, "Đã hủy", "27/04 11:33"),
    };
    var topProducts = new[]
    {
        ("iPhone 15 Pro Max", 124, 3_476_760_000m),
        ("Samsung Galaxy S26 Ultra", 87, 2_088_000_000m),
        ("Xiaomi 17 Ultra", 65, 1_424_000_000m),
        ("Redmi Note 15", 51, 612_000_000m),
        ("MacBook Air M4", 32, 896_000_000m),
    };
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h4 class="mb-1 fw-semibold">Dashboard</h4>
        <div class="page-breadcrumb">Tổng quan hiệu suất bán hàng</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-danger btn-sm" asp-action="Orders">Đến quản lý đơn hàng</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-3 col-sm-6">
        <div class="admin-card border-start border-4 border-success">
            <div class="text-muted small">Doanh thu hôm nay</div>
            <div class="h4 mb-1">128.450.000đ</div>
            <div class="small text-success">↑ 12% so với hôm qua</div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="admin-card border-start border-4 border-warning">
            <div class="text-muted small">Đơn hàng mới</div>
            <div class="h4 mb-1">42</div>
            <div class="small text-muted">8 đơn chờ xử lý</div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="admin-card border-start border-4" style="border-color:#6f42c1!important;">
            <div class="text-muted small">Khách hàng mới</div>
            <div class="h4 mb-1">17</div>
            <div class="small text-muted">Tổng: 1.284 khách</div>
        </div>
    </div>
    <div class="col-lg-3 col-sm-6">
        <div class="admin-card border-start border-4 border-danger">
            <div class="text-muted small">Sắp hết hàng</div>
            <div class="h4 mb-1 text-danger">5</div>
            <div class="small"><a href="#" class="text-danger text-decoration-none">Xem chi tiết →</a></div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-6">
        <div class="admin-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">Đơn hàng gần đây</h6>
                <a asp-action="Orders" class="small text-decoration-none">Xem tất cả →</a>
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Tổng</th><th>Trạng thái</th><th>Thời gian</th></tr></thead>
                    <tbody>
                    @foreach (var x in recentOrders)
                    {
                        <tr>
                            <td><span class="text-danger fw-semibold">#@x.Item1</span></td>
                            <td>@x.Item2</td>
                            <td>@x.Item3.ToString("N0")đ</td>
                            <td><span class="badge text-bg-light border">@x.Item4</span></td>
                            <td class="text-muted">@x.Item5</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="admin-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">Top sản phẩm</h6>
                <span class="badge text-bg-light">7 ngày qua</span>
            </div>
            @{
                var maxSold = topProducts.Max(x => x.Item2);
            }
            @for (var i = 0; i < topProducts.Length; i++)
            {
                var p = topProducts[i];
                var percent = (int)Math.Round((double)p.Item2 / maxSold * 100);
                <div class="d-flex align-items-center gap-2 mb-2">
                    <strong style="width:24px;">#@(i + 1)</strong>
                    <img src="https://picsum.photos/seed/qdphone-demo/80/80" alt="@p.Item1" style="width:36px;height:36px;object-fit:cover;border-radius:6px;" />
                    <div class="flex-grow-1">
                        <div class="small fw-semibold text-truncate">@p.Item1</div>
                        <div class="progress" style="height:4px;"><div class="progress-bar bg-danger" style="width:@percent%"></div></div>
                    </div>
                    <div class="text-end small">
                        <div>@p.Item2 đã bán</div>
                        <div class="text-muted">@p.Item3.ToString("N0")đ</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="admin-card">
            <h6 class="mb-3">Quick stats</h6>
            <div class="d-flex justify-content-between mb-2"><span>Tổng sản phẩm</span><strong>128</strong></div>
            <div class="d-flex justify-content-between mb-2"><span>Danh mục</span><strong>12</strong></div>
            <div class="d-flex justify-content-between mb-2"><span>Thương hiệu</span><strong>9</strong></div>
            <div class="d-flex justify-content-between mb-2"><span>Tổng đánh giá</span><strong>372</strong></div>
            <div class="d-flex justify-content-between"><span>Coupon đang chạy</span><strong>4</strong></div>
        </div>
    </div>
</div>
