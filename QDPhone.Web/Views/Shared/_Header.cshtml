@using System.Security.Claims
@inject QDPhone.Web.Services.ICartService CartService
@{
    var isAuth = User.Identity?.IsAuthenticated ?? false;
    var cartCount = 0;
    if (isAuth)
    {
        var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrWhiteSpace(userId))
        {
            cartCount = await CartService.GetCartItemCountAsync(userId);
        }
    }
}

<header class="site-header mb-3">
    <!-- Top heading theo style HoangHa -->
    <section class="top-heading">
        <div id="headerDealCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3500">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="deal-header header-top-intro">
                        <a href="#"><span class="material-symbols-outlined icon-inline">verified</span><span>SẢN PHẨM CHÍNH HÃNG</span></a>
                        <a href="#"><span class="material-symbols-outlined icon-inline">sync_alt</span><span>CAM KẾT LỖI ĐỔI LIỀN (*)</span></a>
                        <a href="tel:19002091"><span class="material-symbols-outlined icon-inline">call</span><span>HOTLINE 085 419 4075</span></a>
                        <a href="#"><span class="material-symbols-outlined icon-inline">local_shipping</span><span>MIỄN PHÍ VẬN CHUYỂN TOÀN QUỐC</span></a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main header -->
    <section class="container py-2">
        <div class="logo-search-user">
            <div class="logo">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <span class="brand-logo">QDPhone</span>
                </a>
            </div>

            <div class="search">
                <div class="search-box">
                    <form method="get" asp-controller="Products" asp-action="Index">
                        <div class="search-bg">
                            <input name="q" type="text" placeholder="Hôm nay bạn muốn tìm kiếm gì?" autocomplete="off">
                            <button type="submit">
                                <span class="material-symbols-outlined icon-inline">search</span>
                                <span>Tìm kiếm</span>
                            </button>
                        </div>
                    </form>
                </div>
                <div class="search-suggest">
                    <strong>Từ khóa xu hướng</strong>
                    <a asp-controller="Products" asp-action="Index" asp-route-q="#">Galaxy S26 Series</a>
                    <a asp-controller="Products" asp-action="Index" asp-route-q="#">iPhone 17</a>
                    <a asp-controller="Products" asp-action="Index" asp-route-q="#">Redmi Note 15</a>
                    <a asp-controller="Products" asp-action="Index" asp-route-q="#">Xiaomi 17 Ultra</a>
                </div>
            </div>

            <div class="quick-for-user">
                <a class="text-link" href="#">
                    <span class="material-symbols-outlined icon-inline">location_on</span>
                    <span>Tìm siêu thị</span>
                </a>
                @if (isAuth)
                {
                    <a class="text-link" asp-controller="Account" asp-action="Profile">
                        <span class="material-symbols-outlined icon-inline">person</span>
                        <span>Tài khoản</span>
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="text-link border-0 bg-transparent p-0">
                            <span class="material-symbols-outlined icon-inline">logout</span>
                            <span>Đăng xuất</span>
                        </button>
                    </form>
                    <a class="text-link cart-link" asp-controller="Cart" asp-action="Index">
                        <span class="material-symbols-outlined icon-inline">shopping_cart</span>
                        <label class="cart-counter">@cartCount</label>
                    </a>
                }
                else
                {
                    <a class="text-link" asp-controller="Account" asp-action="Login">
                        <span class="material-symbols-outlined icon-inline">person</span>
                        <span>Đăng nhập</span>
                    </a>
                    <a class="text-link cart-link" asp-controller="Cart" asp-action="Index">
                        <span class="material-symbols-outlined icon-inline">shopping_cart</span>
                        <label class="cart-counter">0</label>
                    </a>
                }
            </div>
        </div>
    </section>

    <nav class="header-nav border-top">
        <div class="container d-flex flex-wrap gap-3 py-2">
            <a asp-controller="Products" asp-action="Index" class="nav-link p-0">Sản phẩm</a>
            <a asp-controller="Orders" asp-action="MyOrders" class="nav-link p-0">Đơn hàng</a>
            <a asp-controller="Notifications" asp-action="Index" class="nav-link p-0">Thông báo</a>
        </div>
    </nav>
</header>
