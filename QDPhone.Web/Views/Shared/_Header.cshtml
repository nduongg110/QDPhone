@{
    var isAuth = User.Identity?.IsAuthenticated ?? false;
}

<header class="site-header mb-3">
    <section class="top-heading">
        <div id="headerDealCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3500">
            <div class="carousel-inner">
                <div class="carousel-item active">
                    <div class="deal-header header-top-intro">
                        <a href="#"><span class="material-symbols-outlined icon-inline">verified</span><span>SẢN PHẨM CHÍNH HÃNG</span></a>
                        <a href="#"><span class="material-symbols-outlined icon-inline">sync_alt</span><span>CAM KẾT LỖI ĐỔI LIỀN (*)</span></a>
                        <a href="tel:19002091"><span class="material-symbols-outlined icon-inline">call</span><span>HOTLINE 1900.2091</span></a>
                        <a href="#"><span class="material-symbols-outlined icon-inline">local_shipping</span><span>MIỄN PHÍ VẬN CHUYỂN TOÀN QUỐC</span></a>
                    </div>
                </div>
                <div class="carousel-item">
                    <a href="#" class="deal-header header-top-sales">
                        <span class="material-symbols-outlined icon-inline">autorenew</span>
                        <span>Thu cũ giá cao toàn bộ sản phẩm</span>
                    </a>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#headerDealCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#headerDealCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </section>

    <section class="container py-2">
        <div class="logo-search-user">
            <div class="logo">
                <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                    <span class="brand-logo">QDPhone</span>
                </a>
            </div>

            <div class="search">
                <div class="search-box">
                    <form method="get" action="#">
                        <div class="search-bg">
                            <input name="q" type="text" placeholder="Hôm nay bạn muốn tìm kiếm gì?" autocomplete="off">
                            <button type="submit">
                                <span class="material-symbols-outlined icon-inline">search</span>
                                <span>Tìm kiếm</span>
                            </button>
                        </div>
                    </form>
                </div>
                <div class="search-suggest">
                    <strong>Từ khóa xu hướng</strong>
                    <a href="#">Galaxy S26 Series</a>
                    <a href="#">iPhone 17</a>
                    <a href="#">Redmi Note 15</a>
                    <a href="#">Xiaomi 17 Ultra</a>
                </div>
            </div>

            <div class="quick-for-user">
                <a class="text-link" href="#">
                    <span class="material-symbols-outlined icon-inline">location_on</span>
                    <span>Tìm siêu thị</span>
                </a>
                @if (isAuth)
                {
                    <a class="text-link" href="#">
                        <span class="material-symbols-outlined icon-inline">person</span>
                        <span>Tài khoản</span>
                    </a>
                    <a class="text-link" href="#">
                        <span class="material-symbols-outlined icon-inline">logout</span>
                        <span>Đăng xuất</span>
                    </a>
                }
                else
                {
                    <a class="text-link" asp-controller="Account" asp-action="Login">
                        <span class="material-symbols-outlined icon-inline">person</span>
                        <span>Đăng nhập</span>
                    </a>
                    <a class="text-link" asp-controller="Account" asp-action="Register">
                        <span class="material-symbols-outlined icon-inline">person_add</span>
                        <span>Đăng ký</span>
                    </a>
                }
            </div>
        </div>
    </section>

    <nav class="header-nav border-top">
        <div class="container d-flex flex-wrap gap-3 py-2">
            <a asp-controller="Products" asp-action="Index" class="nav-link p-0">Sản phẩm</a>
        </div>
    </nav>
</header>
