@model QDPhone.Web.Models.Entities.Product
@{
    var minPrice = Model.Variants.Any() ? Model.Variants.Min(v => v.Price) : 0m;
    var oldPrice = minPrice > 0 ? Math.Round(minPrice * 1.1m, 0) : 0m;
    var discountPercent = oldPrice > minPrice && oldPrice > 0 ? Math.Round((oldPrice - minPrice) * 100 / oldPrice) : 0m;
    var totalStock = Model.Variants.Sum(v => v.StockQuantity);
    var imageUrl = Model.Images
        .OrderBy(x => x.SortOrder)
        .Select(x => x.ImageUrl)
        .FirstOrDefault() ?? $"https://picsum.photos/seed/qdphone-product-{Model.Id}/640/640";
    var firstVariant = Model.Variants.FirstOrDefault();
    var specs = new[]
    {
        ("memory", firstVariant?.Ram ?? "RAM"),
        ("storage", firstVariant?.Rom ?? "ROM"),
        ("palette", firstVariant?.Color ?? "Màu")
    };
}

<!-- Card sản phẩm tái sử dụng cho Home/PLP -->
<div class="product-card h-100 position-relative">
    <a asp-controller="Products" asp-action="Details" asp-route-id="@Model.Id" class="text-decoration-none text-reset d-block h-100">
        <span class="badge badge-sale position-absolute top-0 start-0 m-2">Giảm @discountPercent%</span>
        <div class="product-thumb">
            <img src="@imageUrl" alt="@Model.Name" class="img-fluid" loading="lazy" />
        </div>
        <div class="p-3 d-flex flex-column h-100">
            <h6 class="product-title mb-2">@Model.Name</h6>
            <div class="product-specs mb-2">
                @foreach (var spec in specs)
                {
                    <span class="product-spec-pill">
                        <span class="material-symbols-outlined icon-inline">@spec.Item1</span>
                        @spec.Item2
                    </span>
                }
            </div>
            <div class="star-rating mb-2">★★★★★ <span class="text-muted small">(0 đánh giá)</span></div>
            <div class="price-new">@minPrice.ToString("N0") đ</div>
            <div class="price-old">@oldPrice.ToString("N0") đ</div>
            <div class="product-promo mt-2">
                <span class="material-symbols-outlined icon-inline">local_offer</span>
                Trả góp 0%, giảm thêm khi thanh toán online
            </div>
            <div class="member-price mt-2">Giá thành viên: <strong>@Math.Round(minPrice * 0.97m, 0).ToString("N0") đ</strong></div>
            <div class="small text-muted mt-1">Còn @totalStock sản phẩm</div>
            <span class="btn btn-danger btn-sm w-100 mt-3">Mua ngay</span>
        </div>
    </a>
</div>
