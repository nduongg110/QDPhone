@{
    ViewData["Title"] = "Quản lý sản phẩm";
    var products = new[]
    {
        ("iPhone 15 Pro Max", "iphone-15-pro-max", "iOS 17", "Điện thoại", "Apple", 25, 27_990_000m),
        ("Samsung Galaxy S26 Ultra", "samsung-galaxy-s26-ultra", "Android 15", "Điện thoại", "Samsung", 18, 24_990_000m),
        ("Xiaomi 17 Ultra", "xiaomi-17-ultra", "HyperOS", "Điện thoại", "Xiaomi", 12, 21_990_000m),
        ("MacBook Air M4", "macbook-air-m4", "macOS 15", "Laptop", "Apple", 8, 32_500_000m),
        ("Redmi Note 15", "redmi-note-15", "HyperOS", "Điện thoại", "Xiaomi", 30, 5_490_000m),
    };
    var imageUrl = "https://picsum.photos/seed/qdphone-demo/120/120";
}
<div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h4 class="mb-1 fw-semibold">Quản lý sản phẩm</h4>
        <div class="page-breadcrumb">Danh sách sản phẩm và thông tin hiển thị</div>
    </div>
    <a class="btn btn-danger" href="#"><i class="bi bi-plus-circle"></i> Thêm sản phẩm</a>
</div>

<div class="admin-card">
    <div class="table-responsive">
        <table class="table table-hover admin-table align-middle mb-0">
            <thead><tr><th>Sản phẩm</th><th>SKU/OS</th><th>Danh mục</th><th>Thương hiệu</th><th>Kho</th><th class="text-end">Thao tác</th></tr></thead>
            <tbody>
            @foreach (var p in products)
            {
                <tr>
                    <td>
                        <img src="@imageUrl" alt="@p.Item1" style="width:56px;height:56px;object-fit:cover;border-radius:6px;" class="me-2" />
                        <div class="fw-semibold">@p.Item1</div>
                        <div class="small text-muted">Sản phẩm demo</div>
                    </td>
                    <td><span class="text-muted small">@p.Item2</span><br /><span>@p.Item3</span></td>
                    <td><span class="badge text-bg-light border">@p.Item4</span></td>
                    <td><span class="badge text-bg-light border">@p.Item5</span></td>
                    <td>
                        <span class="@(p.Item6 < 10 ? "text-danger fw-semibold" : "fw-semibold")">@p.Item6</span>
                        <div class="small text-muted">@p.Item7.ToString("N0")đ</div>
                    </td>
                    <td class="text-end">
                        <a href="#" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i> Sửa</a>
                        <a href="#" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Xóa</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
