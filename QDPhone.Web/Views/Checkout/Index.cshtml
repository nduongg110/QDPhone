@model QDPhone.Web.Models.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Thanh toán";
}
<h2 class="mb-3">Thanh toán</h2>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-info">@message</div>
}

@{
    var appliedCode = ViewBag.AppliedCouponCode as string;
    var appliedDiscount = ViewBag.AppliedCouponDiscount as string;
    var appliedFinalTotal = ViewBag.AppliedFinalTotal as string;
    var appliedCouponMessage = ViewBag.AppliedCouponMessage as string;
}

@if (!string.IsNullOrWhiteSpace(appliedCouponMessage))
{
    <div class="alert alert-success">@appliedCouponMessage</div>
}

@if (!string.IsNullOrWhiteSpace(appliedCode) && !string.IsNullOrWhiteSpace(appliedDiscount) && !string.IsNullOrWhiteSpace(appliedFinalTotal))
{
    <div class="alert alert-warning d-flex flex-wrap gap-3 justify-content-between">
        <span>Mã: <strong>@appliedCode</strong></span>
        <span>Giảm: <strong>-@appliedDiscount đ</strong></span>
        <span>Tổng sau giảm: <strong class="text-danger">@appliedFinalTotal đ</strong></span>
    </div>
}

<form method="post" class="card p-4">
    <div class="mb-3">
        <label class="form-label">Địa chỉ giao hàng *</label>
        <input name="shippingAddress"
               class="form-control"
               value="@ViewBag.ShippingAddress"
               placeholder="Nhập địa chỉ..." required />
        <div class="text-danger small">Vui lòng nhập địa chỉ giao hàng</div>
    </div>
    <div class="mb-3">
        <label class="form-label">Số điện thoại *</label>
        <input name="phoneNumber"
               class="form-control"
               value="@ViewBag.PhoneNumber"
               placeholder="Nhập số điện thoại..."
               required pattern="[0-9]{9,11}" />
        <div class="text-danger small">Vui lòng nhập số điện thoại hợp lệ</div>
    </div>
    <div class="mb-3">
        <label class="form-label">Tạm tính giỏ hàng</label>
        <input class="form-control" value="@Model.SubTotal.ToString("N0") đ" readonly />
    </div>
    <div class="mb-3">
        <label class="form-label">Mã khuyến mãi</label>
        <div class="input-group">
            <input class="form-control" name="couponCode" value="@appliedCode" placeholder="Nhập mã ví dụ: WELCOME10" />
            <button type="submit" class="btn btn-outline-primary" formaction="/Checkout/ApplyCoupon">
                Áp dụng
            </button>

        </div>
        <small class="text-muted">Mã sẽ được kiểm tra trước khi thanh toán.</small>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button type="submit" formaction="/Checkout/PlaceCod" class="btn btn-danger w-50">
            Thanh toán COD
        </button>

        <button type="submit" formaction="/Checkout/CreatePayOs" class="btn btn-primary w-50">
            Thanh toán PayOS
        </button>
    </div>

</form>