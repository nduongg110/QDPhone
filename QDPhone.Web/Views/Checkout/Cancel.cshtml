@model QDPhone.Web.Controllers.CheckoutController.PayOsCancelViewModel
@{
    ViewData["Title"] = "Đã huỷ thanh toán";
}

<section class="container py-4">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex align-items-center gap-3 mb-3">
                <span class="material-symbols-outlined text-warning" style="font-size:36px;">cancel</span>
                <div>
                    <h1 class="h4 mb-1">Bạn đã huỷ thanh toán</h1>
                    <p class="text-muted mb-0">Đơn hàng vẫn được lưu, bạn có thể thanh toán lại bất cứ lúc nào.</p>
                </div>
            </div>

            <div class="alert alert-warning mb-4">
                Trạng thái cổng thanh toán: <strong>@Model.Status</strong>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Mã đơn hàng</div>
                        <div class="fw-semibold">@(Model.OrderCode is > 0 ? $"#{Model.OrderCode}" : "Không có")</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Mã phản hồi</div>
                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.Code) ? "-" : Model.Code)</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Mã giao dịch PayOS</div>
                        <div class="fw-semibold text-break">@(string.IsNullOrWhiteSpace(Model.TransactionId) ? "-" : Model.TransactionId)</div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                @if (Model.OrderCode is > 0)
                {
                    <form asp-controller="Orders" asp-action="RetryPayment" method="post">
                        <input type="hidden" name="orderId" value="@Model.OrderCode" />
                        <button type="submit" class="btn btn-danger">Thanh toán lại ngay</button>
                    </form>
                    <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.OrderCode" class="btn btn-outline-secondary">Xem chi tiết đơn</a>
                }
                <a asp-controller="Checkout" asp-action="Index" class="btn btn-outline-primary">Quay lại thanh toán</a>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</section>
