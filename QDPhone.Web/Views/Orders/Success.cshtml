@model QDPhone.Web.Models.Entities.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<section class="container py-4">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex align-items-center gap-3 mb-3">
                <span class="material-symbols-outlined text-success" style="font-size:36px;">check_circle</span>
                <div>
                    <h1 class="h4 mb-1">Đặt hàng thành công</h1>
                    <p class="text-muted mb-0">Cảm ơn bạn đã mua sắm tại QDPhone.</p>
                </div>
            </div>

            <div class="alert alert-success mb-4">
                Đơn hàng <strong>#@Model.Id</strong> đã được ghi nhận.
                Trạng thái hiện tại: <strong>@Model.Status</strong>.
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Mã đơn hàng</div>
                        <div class="fw-semibold">#@Model.Id</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Phương thức thanh toán</div>
                        <div class="fw-semibold">@Model.PaymentMethod</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Tổng thanh toán</div>
                        <div class="fw-semibold text-danger">@Model.TotalAmount.ToString("N0") đ</div>
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Mã giảm giá</div>
                        <div class="fw-semibold">@(string.IsNullOrWhiteSpace(Model.CouponCode) ? "-" : Model.CouponCode)</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="border rounded p-3 h-100">
                        <div class="text-muted small">Số tiền giảm</div>
                        <div class="fw-semibold text-success">@(Model.DiscountAmount > 0 ? $"-{Model.DiscountAmount:N0} đ" : "-")</div>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Orders" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-danger">Xem chi tiết đơn hàng</a>
                <a asp-controller="Orders" asp-action="MyOrders" class="btn btn-outline-secondary">Danh sách đơn hàng</a>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">Tiếp tục mua sắm</a>
            </div>
        </div>
    </div>
</section>
