@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="row g-3">
    <aside class="col-lg-3">
        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Bộ lọc</h5>
                <a href="#" class="small text-decoration-none">Xóa nhanh</a>
            </div>
            <form method="get" action="#" class="d-grid gap-3">
                <input class="form-control" name="q" placeholder="Tên sản phẩm, từ khóa..." />
                <select class="form-select" name="categoryId">
                    <option value="">Danh mục</option>
                    <option value="1">Điện thoại</option>
                    <option value="2">Laptop</option>
                    <option value="3">Phụ kiện</option>
                </select>
                <select class="form-select" name="brandId">
                    <option value="">Thương hiệu</option>
                    <option value="1">Apple</option>
                    <option value="2">Samsung</option>
                    <option value="3">Xiaomi</option>
                </select>
                <div>
                    <label class="form-label mb-1 fw-semibold">Khoảng giá</label>
                    <div class="row g-2">
                        <div class="col-6">
                            <input class="form-control" placeholder="Từ (VND)" />
                        </div>
                        <div class="col-6">
                            <input class="form-control" placeholder="Đến (VND)" />
                        </div>
                    </div>
                    <div class="d-flex flex-wrap gap-1 mt-2">
                        <a href="#" class="btn btn-sm btn-outline-secondary">Dưới 5 triệu</a>
                        <a href="#" class="btn btn-sm btn-outline-secondary">5-10 triệu</a>
                        <a href="#" class="btn btn-sm btn-outline-secondary">10-20 triệu</a>
                        <a href="#" class="btn btn-sm btn-outline-secondary">Trên 20 triệu</a>
                    </div>
                </div>
                <input class="form-control" name="ram" placeholder="RAM" />
                <input class="form-control" name="rom" placeholder="ROM" />
                <input class="form-control" name="os" placeholder="Hệ điều hành" />
                <select class="form-select" name="sort">
                    <option value="">Sắp xếp</option>
                    <option value="price_asc">Giá thấp đến cao</option>
                    <option value="price_desc">Giá cao đến thấp</option>
                    <option value="latest">Mới nhất</option>
                </select>
                <a href="#" class="btn btn-danger">Lọc sản phẩm</a>
                <a href="#" class="btn btn-outline-secondary">Xóa bộ lọc</a>
            </form>
        </div>
    </aside>

    <section class="col-lg-9">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h1 class="h4 mb-0">Danh sách sản phẩm</h1>
            <small class="text-muted">Hiển thị 12/12 sản phẩm</small>
        </div>
        <div class="row g-3 row-cols-2 row-cols-md-3 row-cols-xl-4">
            @for (var i = 0; i < 12; i++)
            {
                <div class="col">
                    <partial name="_ProductCard" />
                </div>
            }
        </div>
    </section>
</div>
