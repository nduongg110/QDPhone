@{
    ViewData["Title"] = "Thương hiệu";
    var brands = new[]
    {
        ("Apple", "apple"),
        ("Samsung", "samsung"),
        ("Xiaomi", "xiaomi"),
        ("Oppo", "oppo"),
    };
}
<div class="page-header d-flex flex-wrap justify-content-between align-items-center mb-4 gap-2">
    <div>
        <h4 class="mb-1 fw-semibold">Quản lý thương hiệu</h4>
        <div class="page-breadcrumb">Danh sách thương hiệu đang hoạt động</div>
    </div>
    <a class="btn btn-danger" href="#"><i class="bi bi-plus-circle"></i> Thêm thương hiệu</a>
</div>
<div class="admin-card">
    <div class="row g-3">
        @foreach (var b in brands)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="border rounded p-3 h-100">
                    <img src="https://picsum.photos/seed/qdphone-demo/120/60" alt="@b.Item1" style="width:96px;height:48px;object-fit:cover;" class="mb-2" />
                    <div class="fw-semibold">@b.Item1</div>
                    <div class="small text-muted"><code>@b.Item2</code></div>
                    <div class="mt-2 d-flex gap-2">
                        <a href="#" class="btn btn-sm btn-outline-primary">Sửa</a>
                        <a href="#" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
