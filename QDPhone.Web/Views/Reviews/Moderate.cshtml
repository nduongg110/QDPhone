@model QDPhone.Web.Models.ViewModels.AdminReviewModerationIndexViewModel
@{
    ViewData["Title"] = "Kiểm duyệt đánh giá";
    var pendingCount = Model.Rows.Count(x => !x.IsApproved);
    var approvedCount = Model.Rows.Count(x => x.IsApproved);
}
<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 fw-semibold">Kiểm duyệt đánh giá</h4>
        <div class="page-breadcrumb">Duyệt hoặc xóa review từ người dùng</div>
    </div>
    <div class="d-flex gap-2">
        <span class="badge text-bg-warning">Chờ duyệt: @pendingCount</span>
        <span class="badge text-bg-success">Đã duyệt: @approvedCount</span>
    </div>
</div>
<div class="admin-card">
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <select class="form-select" name="status">
                <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Status) ? "selected" : null)">Tất cả trạng thái</option>
                <option value="pending" selected="@(Model.Status == "pending" ? "selected" : null)">Chờ duyệt</option>
                <option value="approved" selected="@(Model.Status == "approved" ? "selected" : null)">Đã duyệt</option>
            </select>
        </div>
        <div class="col-md-6"><input class="form-control" name="q" value="@Model.Q" placeholder="Tìm theo nội dung hoặc mã sản phẩm..." /></div>
        <div class="col-md-3 d-grid d-md-flex gap-2">
            <button class="btn btn-outline-primary">Lọc</button>
            <a asp-action="Moderate" class="btn btn-outline-secondary">Xóa lọc</a>
        </div>
    </form>
    <div class="table-responsive">
        <table class="table table-hover admin-table mb-0">
            <thead><tr><th>ID</th><th>Sản phẩm</th><th>Điểm</th><th>Nội dung</th><th>Trạng thái</th><th class="text-end">Thao tác</th></tr></thead>
            <tbody>
            @foreach (var review in Model.Rows)
            {
                <tr>
                    <td>#@review.Id</td>
                    <td>@review.ProductId</td>
                    <td><span class="text-warning">@(new string('★', Math.Max(1, review.Rating)))</span></td>
                    <td>@review.Comment</td>
                    <td><span class="badge js-review-status-badge @(review.IsApproved ? "text-bg-success" : "text-bg-warning")">@(review.IsApproved ? "Đã duyệt" : "Chờ duyệt")</span></td>
                    <td class="text-end">
                        @if (!review.IsApproved)
                        {
                            <form asp-action="Approve" method="post" class="d-inline js-ajax-form js-review-approve-form" data-success-message="Đã duyệt đánh giá." data-reload="none" data-update="review-approve">
                                <input type="hidden" name="id" value="@review.Id" />
                                <button class="btn btn-sm btn-outline-success">Duyệt</button>
                            </form>
                        }
                        <form asp-action="Delete" method="post" class="d-inline js-ajax-form" data-success-message="Đã xóa đánh giá." data-confirm="Xóa đánh giá này?" data-reload="row">
                            <input type="hidden" name="id" value="@review.Id" />
                            <button class="btn btn-sm btn-outline-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : null)">
                <a class="page-link" asp-action="Moderate" asp-route-status="@Model.Status" asp-route-q="@Model.Q" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Trước</a>
            </li>
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : null)">
                    <a class="page-link" asp-action="Moderate" asp-route-status="@Model.Status" asp-route-q="@Model.Q" asp-route-page="@p" asp-route-pageSize="@Model.PageSize">@p</a>
                </li>
            }
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : null)">
                <a class="page-link" asp-action="Moderate" asp-route-status="@Model.Status" asp-route-q="@Model.Q" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Sau</a>
            </li>
        </ul>
    </nav>
}
