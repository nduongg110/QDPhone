@model QDPhone.Web.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}
<div class="auth-card mx-auto">
    <div class="text-center mb-3">
        <h2 class="mb-1">Đăng nhập</h2>
        <p class="text-secondary mb-0">Chào mừng trở lại! Đăng nhập để tiếp tục</p>
    </div>
    @if (TempData["Error"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-danger">@err</div>
    }
    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" placeholder="Email hoặc SĐT" />
        </div>
        <div class="mb-3">
            <label asp-for="Password"></label>
            <input asp-for="Password" class="form-control" />
        </div>
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <label class="mb-0">
                <input asp-for="RememberMe" /> Ghi nhớ đăng nhập
            </label>
            <a href="#" class="text-danger" onclick="alert('Chức năng này hiện chưa hỗ trợ'); return false;">
                Quên mật khẩu?
            </a>
        </div>
        <button class="btn btn-danger w-100" type="submit">ĐĂNG NHẬP</button>
    </form>
    <hr />
    <form asp-action="ExternalLogin" method="post" class="mb-3">
        <input type="hidden" name="provider" value="Google" />
        <button type="submit" class="btn btn-outline-dark w-100">Đăng nhập bằng Google</button>
    </form>
    <p class="text-center mb-0">Chưa có tài khoản? <a asp-action="Register" class="text-danger">Đăng ký ngay</a></p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
