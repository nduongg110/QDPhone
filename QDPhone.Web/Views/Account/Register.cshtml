@model QDPhone.Web.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}
<div class="auth-card mx-auto">
    <div class="text-center mb-3">
        <h2 class="mb-1">Tạo tài khoản mới</h2>
    </div>
    <form method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label asp-for="FullName"></label>
            <input asp-for="FullName" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Password"></label>
            <input asp-for="Password" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" class="form-control" />
        </div>
        <button class="btn btn-danger w-100" type="submit">TẠO TÀI KHOẢN</button>
    </form>
    <p class="text-center mt-3 mb-0">Đã có tài khoản? <a asp-action="Login" class="text-danger">Đăng nhập</a></p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
